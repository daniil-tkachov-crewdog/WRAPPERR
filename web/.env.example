# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — used only server-side for account deletion
# Keep this secret — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=

# Chrome extension ID — available after publishing to Chrome Web Store
NEXT_PUBLIC_EXTENSION_ID=

# Public URL of this app on Render (no trailing slash)
# e.g. https://wrapperr.onrender.com
NEXT_PUBLIC_APP_URL=
